# ============================================================
# Stash — FRONTEND (Next.js on Vercel) environment
# Copy to .env.local for local dev. Backend vars: backend/.env.example
# ============================================================

# --- Required ---

# Express backend URL (Railway in prod, localhost in dev)
NEXT_PUBLIC_UPLOAD_SERVER=http://localhost:5050

# Public URL of this frontend (used in magic-link emails)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Server-to-server secret shared with the backend (X-Admin-Secret header).
# MUST match backend ADMIN_BACKEND_SECRET. Frontend↔backend calls 401 without it.
ADMIN_BACKEND_SECRET=generate_a_long_random_hex_string

# Admin login password — ALSO the HMAC signing key for session cookies,
# magic-link tokens, and the anonymous upload limiter. Make it long + random.
ADMIN_PASSWORD=generate_a_long_random_string

# Resend API key — magic-link sign-in emails are dead without it
RESEND_API_KEY=re_xxxxxxxxxxxx

# --- Optional ---

# Comma-separated emails allowed into /admin (in addition to is_admin flag)
# ALLOWED_ADMIN_EMAILS=you@example.com

# Sender for auth/alert emails (default: alerts@offsetworks.xyz)
# ALERT_FROM=alerts@offsetworks.xyz

# Anonymous upload limit per browser before sign-up prompt (default 1)
# MAX_ANONYMOUS_UPLOADS=1

# Max upload size in MB shown to users (default 6144 = 6GB)
# MAX_FILE_SIZE_MB=6144

# --- Legacy (Supabase remnants — only the unused /api/claim path; safe to omit) ---
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
