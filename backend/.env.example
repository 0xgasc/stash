# ============================================================
# Stash — BACKEND (Express on Railway) environment
# Copy to backend/.env for local dev.
# ============================================================

# --- Required ---

# EVM wallet private key that funds Irys uploads (Sepolia devnet)
PRIVATE_KEY=your_wallet_private_key

# Ethereum Sepolia RPC endpoint
SEPOLIA_RPC=https://ethereum-sepolia-rpc.publicnode.com

# Server-to-server secret — MUST match the frontend's ADMIN_BACKEND_SECRET.
# Without it the backend silently ignores user_id on uploads.
ADMIN_BACKEND_SECRET=generate_a_long_random_hex_string

# CORS origins, comma-separated
ALLOWED_ORIGINS=http://localhost:3000,https://aeter-eight.vercel.app,https://stash.offsetworks.xyz

# Frontend base URL for checkout success/cancel redirects
FRONTEND_URL=https://stash.offsetworks.xyz

# --- Payments (required to charge) ---

# Stripe: secret key + webhook signing secret
# Webhook URL: https://<railway-domain>/api/v1/webhook/stripe
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Recurrente webhook signing secret
# Webhook URL: https://<railway-domain>/api/v1/webhook/recurrente
RECURRENTE_SECRET_KEY=

# StablePay webhook signing secret — REQUIRED for crypto payments to
# activate (webhooks fail closed without it; client events are not trusted)
# Webhook URL: https://<railway-domain>/api/v1/webhook/stablepay
STABLEPAY_WEBHOOK_SECRET=

# --- Alerts (recommended) ---

RESEND_API_KEY=re_xxxxxxxxxxxx
ALERT_FROM=alerts@offsetworks.xyz
ALERT_TO=you@example.com

# --- Optional tuning ---

# PORT=5050
# DB_PATH=/data/stash.db                # Railway volume mount in prod
# ANON_DAILY_IP_LIMIT=3                 # anonymous uploads per IP per day
# REUPLOAD_AFTER_DAYS=50                # re-upload threshold (devnet evicts ~60d)
# REUPLOAD_MAX_PER_RUN=10
# REUPLOAD_CRON_DISABLED=0
# ALERT_CRON_DISABLED=0
# SEPOLIA_LOW_THRESHOLD=0.05            # ETH balance alert threshold
# IRYS_LOW_THRESHOLD=0.01               # Irys balance alert threshold
# IRYS_AUTO_FUND_AMOUNT=0
# LINK_EXPIRY_DAYS=60
